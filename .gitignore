# Ignore tinkering
assets/config.json

# Ignore training data files (these can get large and bloat the repo)
assets/training_data/

# Design artefacts
workflow/
scripts/

# "Scratchpad", where candidate models are saved
incubator/

# Pycaches (these bloat the repo if not .gitignored)
__pycache__/
*.pyc

# Venv, environment vars
.venv
*.env
*.envrc

# Auto-generated junk
.DS_Store
Thumbs.db

# Script artefacts (from normal or deprecated scripts)
digits.csv
*.bak
*.bkp
*.log
